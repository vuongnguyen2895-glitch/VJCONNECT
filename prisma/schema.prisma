generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String    @map("password_hash")
  name          String
  cccd          String?   // Căn cước công dân
  address       String?
  avatarUrl     String?   @map("avatar_url")

  // Subscription
  plan          Plan      @default(FREE)
  planExpiresAt DateTime? @map("plan_expires_at")

  // Timestamps
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  emailVerifiedAt DateTime? @map("email_verified_at")

  // Relations
  contracts     Contract[]     @relation("ContractOwner")
  partyRecords  ContractParty[]
  notifications Notification[]
  sessions      Session[]
  buildings     Building[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OtpCode {
  id        String   @id @default(cuid())
  target    String   // email or phone
  code      String
  type      OtpType  @default(EMAIL)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([target, code])
  @@map("otp_codes")
}

// ============================================================
// CONTRACT TEMPLATES
// ============================================================

model Template {
  id          String   @id @default(cuid())
  name        String   // "Nhà nguyên căn", "Chung cư"...
  slug        String   @unique
  category    TemplateCategory
  description String?
  icon        String?  // emoji or icon name
  contentJson Json     @map("content_json") // template structure
  version     Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  isPremium   Boolean  @default(false) @map("is_premium")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  contracts   Contract[]

  @@map("templates")
}

// ============================================================
// BUILDINGS (Nhà / Căn hộ — groups multiple room contracts)
// ============================================================

model Building {
  id               String   @id @default(cuid())
  ownerId          String   @map("owner_id")
  name             String   // "Nhà số 12 Lê Lợi", "Chung cư ABC"
  address          String?
  electricityPrice Decimal? @map("electricity_price") @db.Decimal(12, 0) // đồng/kWh, dùng chung cho cả nhà
  waterPrice       Decimal? @map("water_price") @db.Decimal(12, 0) // đồng/m³, dùng chung cho cả nhà

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@index([ownerId])
  @@map("buildings")
}

// ============================================================
// CONTRACTS
// ============================================================

model Contract {
  id          String         @id @default(cuid())
  contractNo  String?        @unique @map("contract_no") // VJC-2026-00001
  templateId  String         @map("template_id")
  ownerId     String         @map("owner_id")
  status      ContractStatus @default(DRAFT)
  title       String?

  // Contract data (all form fields as JSON)
  dataJson    Json           @map("data_json")

  // Groups this contract (room) under a Building (nhà/căn hộ), for billing management
  buildingId  String?        @map("building_id")
  roomName    String?        @map("room_name") // "Phòng 101", "Tầng 2"...

  // Important dates
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  signedAt    DateTime?      @map("signed_at")

  // Rent info (denormalized for quick access)
  rentAmount  Decimal?       @map("rent_amount") @db.Decimal(15, 0)
  deposit     Decimal?       @db.Decimal(15, 0)

  // Timestamps
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  template    Template       @relation(fields: [templateId], references: [id])
  owner       User           @relation("ContractOwner", fields: [ownerId], references: [id])
  building    Building?      @relation(fields: [buildingId], references: [id])
  parties     ContractParty[]
  files       ContractFile[]
  activities  ContractActivity[]
  invoices    Invoice[]

  @@index([ownerId, status])
  @@index([status, endDate])
  @@index([buildingId])
  @@map("contracts")
}

model ContractParty {
  id           String    @id @default(cuid())
  contractId   String    @map("contract_id")
  role         PartyRole
  userId       String?   @map("user_id") // nullable: tenant may not have account yet

  // Party info (snapshot at signing time)
  partyKind    PartyKind @default(INDIVIDUAL) @map("party_kind")
  name         String    // person's full name, or company name if partyKind = COMPANY
  cccd         String?
  phone        String?
  email        String?
  address      String?

  // Individual-only fields
  dob             String?   @map("dob") // Sinh năm (year or free-text date of birth)
  idIssueDate     DateTime? @map("id_issue_date") // Ngày cấp CCCD
  idIssuePlace    String?   @map("id_issue_place") // Nơi cấp CCCD

  // Company-only fields
  businessRegNo          String? @map("business_reg_no") // Mã số doanh nghiệp
  representativeName     String? @map("representative_name") // Người đại diện
  representativePosition String? @map("representative_position") // Chức vụ

  // Signing
  signedAt     DateTime? @map("signed_at")
  signatureRef String?   @map("signature_ref") // VNPT SmartCA reference
  signingUrl   String?   @map("signing_url")
  signingExpAt DateTime? @map("signing_exp_at")

  // Timestamps
  createdAt    DateTime  @default(now()) @map("created_at")

  contract     Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id])

  @@unique([contractId, role])
  @@map("contract_parties")
}

model ContractFile {
  id         String   @id @default(cuid())
  contractId String   @map("contract_id")
  fileType   FileType @map("file_type")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileSize   Int?     @map("file_size") // bytes
  createdAt  DateTime @default(now()) @map("created_at")

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_files")
}

model ContractActivity {
  id         String   @id @default(cuid())
  contractId String   @map("contract_id")
  action     String   // "created", "sent_for_signing", "signed_by_landlord", etc.
  actorId    String?  @map("actor_id")
  actorName  String?  @map("actor_name")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@map("contract_activities")
}

// ============================================================
// INVOICES (Phiếu tính tiền hàng tháng — theo từng hợp đồng/phòng)
// ============================================================

model Invoice {
  id         String @id @default(cuid())
  contractId String @map("contract_id")
  year       Int
  month      Int // 1-12

  rentAmount Decimal @map("rent_amount") @db.Decimal(15, 0)

  // Điện — theo chỉ số cũ/mới × đơn giá (nếu bên thuê tự trả theo chỉ số), hoặc số tiền khoán cố định
  electricityOldReading Decimal? @map("electricity_old_reading") @db.Decimal(12, 2)
  electricityNewReading Decimal? @map("electricity_new_reading") @db.Decimal(12, 2)
  electricityUnitPrice  Decimal? @map("electricity_unit_price") @db.Decimal(12, 0)
  electricityAmount     Decimal  @default(0) @map("electricity_amount") @db.Decimal(15, 0)

  // Nước — tương tự điện
  waterOldReading Decimal? @map("water_old_reading") @db.Decimal(12, 2)
  waterNewReading Decimal? @map("water_new_reading") @db.Decimal(12, 2)
  waterUnitPrice  Decimal? @map("water_unit_price") @db.Decimal(12, 0)
  waterAmount     Decimal  @default(0) @map("water_amount") @db.Decimal(15, 0)

  internetAmount   Decimal @default(0) @map("internet_amount") @db.Decimal(15, 0)
  serviceFeeAmount Decimal @default(0) @map("service_fee_amount") @db.Decimal(15, 0)
  otherAmount      Decimal @default(0) @map("other_amount") @db.Decimal(15, 0)
  otherNote        String? @map("other_note")

  totalAmount Decimal @map("total_amount") @db.Decimal(15, 0)

  status InvoiceStatus @default(UNPAID)
  paidAt DateTime?     @map("paid_at")
  note   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, year, month])
  @@index([contractId, year, month])
  @@map("invoices")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // "contract_signed", "contract_expiring", etc.
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ============================================================
// ENUMS
// ============================================================

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum OtpType {
  EMAIL
  SMS
}

enum TemplateCategory {
  HOUSE        // Nhà nguyên căn
  APARTMENT    // Chung cư / Căn hộ
  ROOM         // Phòng trọ
  COMMERCIAL   // Mặt bằng kinh doanh
  WAREHOUSE    // Kho xưởng
  LAND         // Đất trống
}

enum ContractStatus {
  DRAFT              // Bản nháp
  PENDING_LANDLORD   // Chờ chủ nhà ký
  PENDING_TENANT     // Chờ người thuê ký
  SIGNED             // Đã ký
  EXPIRED            // Hết hạn
  TERMINATED         // Đã thanh lý
}

enum PartyRole {
  LANDLORD   // Bên cho thuê (Bên A)
  TENANT     // Bên thuê (Bên B)
}

enum PartyKind {
  INDIVIDUAL // Cá nhân
  COMPANY    // Công ty
}

enum FileType {
  DRAFT_PDF      // PDF bản nháp
  SIGNED_PDF     // PDF đã ký
  ATTACHMENT     // Tài liệu đính kèm
}

enum InvoiceStatus {
  UNPAID // Chưa thanh toán
  PAID   // Đã thanh toán
}
