# ============================================================
# DATABASE
# ============================================================
# PostgreSQL - Supabase hoặc Neon recommended
DATABASE_URL="postgresql://user:password@localhost:5432/vjconnect?schema=public"

# ============================================================
# AUTH
# ============================================================
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-jwt-secret-change-this"
JWT_EXPIRES_IN="7d"

# ============================================================
# EMAIL (SendGrid hoặc AWS SES)
# ============================================================
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASSWORD="your-sendgrid-api-key"
EMAIL_FROM="noreply@vjconnect.com"

# ============================================================
# SMS (Twilio hoặc SpeedSMS VN)
# ============================================================
SMS_PROVIDER="speedsms"  # "twilio" | "speedsms" | "esms"
SMS_API_KEY="your-sms-api-key"
SMS_BRAND_NAME="VJConnect"

# ============================================================
# VNPT SmartCA (Phase 2 - thêm sau)
# ============================================================
# VNPT_SMARTCA_API_URL="https://sandbox-smartca.vnpt.vn/api"
# VNPT_SMARTCA_CLIENT_ID=""
# VNPT_SMARTCA_CLIENT_SECRET=""
# VNPT_SMARTCA_CALLBACK_URL="https://vjconnect.com/api/signing/callback"

# ============================================================
# STORAGE (AWS S3 hoặc Cloudflare R2)
# ============================================================
S3_BUCKET="vjconnect-files"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""  # For R2: https://xxx.r2.cloudflarestorage.com

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VJConnect"
